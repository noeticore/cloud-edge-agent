# ── 最小原型只需要填这一项 ──────────────────────────
CLOUD_LLM_API_KEY=sk-your-deepseek-api-key-here

# ── 以下为默认值，一般不用改 ────────────────────────
CLOUD_LLM_PROVIDER=deepseek
CLOUD_LLM_BASE_URL=https://api.deepseek.com/v1
CLOUD_LLM_MODEL_NAME=deepseek-chat
CLOUD_LLM_TEMPERATURE=0.7
CLOUD_LLM_MAX_TOKENS=4096

# ================================
# Qdrant 向量数据库配置
# ================================
# 使用Qdrant云服务 (推荐)
QDRANT_URL= 
QDRANT_API_KEY=

# Qdrant集合配置 (使用MiniLM嵌入，维度384)
QDRANT_COLLECTION=edge_cloud_agent
QDRANT_VECTOR_SIZE=384

